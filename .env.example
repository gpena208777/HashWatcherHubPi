# Hostname written by the agent status API/UI
PI_HOSTNAME=HashWatcherHub

# Bitaxe endpoint(s). Prefer /system/info for AxeOS 2.x, fallback handles legacy.
BITAXE_HOST=192.168.0.12
BITAXE_SCHEME=http
BITAXE_ENDPOINTS=/system/info,/api/system/info

# Polling
POLL_SECONDS=5
HTTP_TIMEOUT_SECONDS=5

# Local status webpage/API for app pairing/debugging
STATUS_HTTP_BIND=0.0.0.0
STATUS_HTTP_PORT=8787
RUNTIME_CONFIG_PATH=/opt/hashwatcher-hub-pi/runtime_config.json
HUB_IDENTITY_PATH=/opt/hashwatcher-hub-pi/hub_identity.json

# Backend ingest (HashWatcherHubPi project for testing)
BACKEND_BASE_URL=https://us-central1-hashwatcher-cd964.cloudfunctions.net
BACKEND_REGISTER_PATH=/registerHub
BACKEND_CLAIM_PATH=/claimHub
BACKEND_ISSUE_TOKEN_PATH=/issueHubToken
BACKEND_REFRESH_TOKEN_PATH=/refreshHubToken
BACKEND_INGEST_PATH=/ingestHubTelemetry
BACKEND_MANIFEST_PATH=/getHubUpdateManifest
BACKEND_REPORT_UPDATE_PATH=/reportHubUpdateStatus
BACKEND_TIMEOUT_SECONDS=10
WIFI_INTERFACE=wlan0
ENABLE_FILE_UPLOAD_API=false

UPDATE_POLL_SECONDS=300
UPDATE_CHANNEL=stable
CURRENT_AGENT_VERSION=pi-agent-v1
UPDATE_STATE_PATH=/opt/hashwatcher-hub-pi/update_state.json
UPDATE_WORK_DIR=/opt/hashwatcher-hub-pi/updates

# IDs
AGENT_ID=pi-zero2-bridge-01
DEVICE_ID=auto
